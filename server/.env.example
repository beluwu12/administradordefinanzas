# ══════════════════════════════════════════════════════════════
# PERSONAL FINANCE APP - Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
# Docker local (default for development)
DATABASE_URL="postgresql://finanzas:finanzas123@localhost:5432/finanzas"

# Supabase (production) - replace with your Supabase connection string
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────
# JWT secret key - REQUIRED
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET="your-super-secure-jwt-secret-change-in-production-minimum-32-characters"

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
# Node environment: development | production
NODE_ENV="development"

# Server port
PORT=3000

# ─────────────────────────────────────────────────────────────
# CORS (Required for production)
# ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Development defaults are used if not set
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173,http://localhost"

# Production example:
# CORS_ALLOWED_ORIGINS="https://remix-of-fincontrol-insights.vercel.app"

# ─────────────────────────────────────────────────────────────
# SCALING / CLUSTERING
# ─────────────────────────────────────────────────────────────
# Instance ID for cron job deduplication in scaled environments
# Set to "1" for primary instance, other values for replicas
INSTANCE_ID="1"

# ─────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────
# Enable automatic BCV rate fetching cron job
# Only runs on primary instance (INSTANCE_ID=1)
CRON_ENABLED="false"

# ─────────────────────────────────────────────────────────────
# LOGGING (Optional)
# ─────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL="info"

# ─────────────────────────────────────────────────────────────
# SECURITY FEATURE FLAGS
# ─────────────────────────────────────────────────────────────
# Enable rate limiting on auth endpoints (login/register/refresh)
FEATURE_RATE_LIMIT_ENABLED="true"

# Enable refresh token rotation (more secure, recommended for production)
FEATURE_ROTATE_REFRESH="true"

# Enable CSRF protection for cookie-based endpoints
FEATURE_CSRF_ENABLED="false"

# Cookie SameSite policy: strict | lax | none
# Use 'strict' for same-origin, 'lax' for cross-site with top-level navigation
COOKIE_SAME_SITE="strict"
